{
  "name": "@guide01/protocol",
  "version": "1.0.2",
  "description": "TypeScript/WASM bindings for the Guide01 protocol (protocol byte generation/parsing only, no BLE)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test \"test/*.test.mjs\""
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "license": "UNLICENSED",
  "private": true
}
